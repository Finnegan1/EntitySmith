@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Sample User Instances
ex:User_1 a ex:User ;
    ex:hasName "Alice Smith" ;
    ex:hasEmail "alice@ex.com" .

ex:User_2 a ex:User ;
    ex:hasName "Bob Johnson" ;
    ex:hasEmail "bob@ex.com" .

# Sample Product Instances
ex:Product_P001 a ex:Product ;
    ex:hasProductName "Basic Widget" ;
    ex:hasDescription "A basic widget for everyday use" ;
    ex:hasPrice 49.99 ;
    ex:hasCategory "Widgets" .

ex:Product_P002 a ex:Product ;
    ex:hasProductName "Advanced Widget" ;
    ex:hasDescription "An advanced widget with extra features" ;
    ex:hasPrice 69.99 ;
    ex:hasCategory "Widgets" .

# Sample Order Instances
ex:Order_ORD-001 a ex:Order ;
    ex:hasOrderDate "2023-01-12"^^xsd:date ;
    ex:hasTotalAmount 99.99 ;
    ex:hasStatus "completed" .

ex:Order_ORD-002 a ex:Order ;
    ex:hasOrderDate "2023-02-18"^^xsd:date ;
    ex:hasTotalAmount 149.99 ;
    ex:hasStatus "completed" .

# Relationships
ex:User_1 ex:places ex:Order_ORD-001 .
ex:User_1 ex:places ex:Order_ORD-002 .
ex:Order_ORD-001 ex:contains ex:OrderItem_1 .
ex:Order_ORD-001 ex:contains ex:OrderItem_2 .
ex:OrderItem_1 ex:references ex:Product_P001 .
ex:OrderItem_2 ex:references ex:Product_P002 .